# RVM Designações - Environment Variables Example
# Copy this file to .env and fill in your values

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# service_role — bypassa RLS; obtido via: Dashboard > Project API Keys > service_role
# OU: Management API GET /v1/projects/{ref}/api-keys (requer PAT com scope projects.read)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-here

# Backend Python URL (FastAPI)
# - For development: http://localhost:8000
# - For production: Your deployed backend URL (Railway, Fly.io, etc)
VITE_BACKEND_URL=http://localhost:8000

# Script Python scripts/import_rm_from_glide.py — conexão direta Postgres (psycopg2, bypassa PostgREST/RLS)
# Obter: Supabase Dashboard > Project Settings > Database > Connection string (URI) > Session mode
# Formato: postgresql://postgres:[SENHA-DB]@db.<project-ref>.supabase.co:5432/postgres
RM_DATABASE_URL=postgresql://postgres:[SENHA-DB]@db.pevstuyzlewvjidjkmea.supabase.co:5432/postgres
